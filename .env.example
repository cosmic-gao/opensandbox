# --- OpenSandbox 连接 -------------------------------------------------------
# 未显式传入 ConnectionConfigSync 时,Python SDK 会读取以下变量。
# 指向你的 OpenSandbox 服务端。以本地 Docker 运行时为例:
#   uvx opensandbox-server init-config ~/.sandbox.toml --example docker
#   uvx opensandbox-server
# 默认地址为 localhost:8080。
OPEN_SANDBOX_DOMAIN=localhost:8080
# 沙箱服务端的 API key(若服务端未开启鉴权可留空)。
OPEN_SANDBOX_API_KEY=

# --- LLM 提供方(仅 LLM 智能体示例需要)------------------------------------
# 任意 LangChain 支持的提供方均可;本示例使用 OpenAI。
OPENAI_API_KEY=
